[server]
cp1 ansible_host=CONTROL_PLANE_PUBLIC_IP private_ip=CONTROL_PLANE_PRIVATE_IP

[agents]
worker1 ansible_host=WORKER_1_PUBLIC_IP private_ip=WORKER_1_PRIVATE_IP
worker2 ansible_host=WORKER_2_PUBLIC_IP private_ip=WORKER_2_PRIVATE_IP

[k3s_cluster:children]
server
agents

[k3s_cluster:vars]
ansible_user=ubuntu
ansible_ssh_common_args='-o StrictHostKeyChecking=accept-new'
